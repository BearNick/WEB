# Copy this file to config/contact.env and replace the values you need below.
# Messages are stored locally in var/contact_messages.php.
# Local storage is primary. PHP mail() notification is secondary.

CONTACT_RECIPIENT_EMAIL=nikolay.ishchenko@gmail.com
MAIL_FROM_EMAIL=hello@slaynet.fun
MAIL_FROM_NAME=SlayNet Contact Form

# Optional: extra sendmail flags, for example: -f hello@slaynet.fun
MAIL_EXTRA_PARAMS=

# Optional: protects /api/messages.php for internal lead review.
ADMIN_REVIEW_TOKEN=replace-me
